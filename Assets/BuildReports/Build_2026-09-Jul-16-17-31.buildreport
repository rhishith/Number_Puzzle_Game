  m_BuildSteps:
  - stepName: Build player
    durationTicks: 227091957
    depth: 0
    messages: []
  - stepName: Preprocess Player
    durationTicks: 762488
    depth: 1
    messages:
    - type: 3
      content: "1 URP assets included in build\r\n- UniversalRP - Assets/Settings/UniversalRP.asset\r\n\t
        - Renderer2D - Assets/Settings/Renderer2D.asset - UnityEngine.Rendering.Universal.Renderer2DData\r\n"
  - stepName: Prepare For Build
    durationTicks: 109189
    depth: 1
    messages:
    - type: 2
      content: Diagnostics Data is enabled, and it requires Debug Symbols to be either
        SymbolTable or Full to resolve stacktraces in crash reports. Consider selecting
        Full to receive fully-detailed crash reports.
    - type: 2
      content: 'Active Input Handling is set to "Both" in Player Settings.


        This
        is not supported on Android and might cause input and performance issues.


        To
        resolve this, select a single active input handling method under Project
        Settings > Player > Active Input Handling.'
  - stepName: ProducePlayerScriptAssemblies
    durationTicks: 4419098
    depth: 1
    messages: []
  - stepName: Prebuild Cleanup and Recompile
